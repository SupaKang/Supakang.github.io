---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  { label: 'GitHub',  handle: 'SupaKang',         href: 'https://github.com/SupaKang' },
  { label: 'Email',   handle: 'seankangster@gmail.com', href: 'mailto:seankangster@gmail.com' },
  { label: 'Twitter', handle: '@supakng1996',     href: 'https://twitter.com/supakng1996' },
];
---
<BaseLayout title="Contact | supablog" description="연락처 — GitHub / Email / Twitter">
  <section class="section">
    <h1>Contact</h1>
    <p class="text-secondary mt-16">아래 채널 중 편한 곳으로 연락 가능.</p>
  </section>

  <section class="section">
    <div class="contact-list">
      {links.map(l => (
        <a href={l.href} class="contact-card" rel="me noopener" target="_blank">
          <div class="text-secondary">{l.label}</div>
          <div class="contact-handle mt-8">{l.handle}</div>
          <div class="text-secondary mt-16">→ {l.href}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .section { margin: 48px 0; }
  .contact-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .contact-card {
    padding: 26px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-ghost-white);
    border-bottom: 1px solid var(--color-muted-ash);
    transition: background 120ms ease;
  }
  .contact-card:hover { background: var(--color-steel-gray); }
  .contact-handle { font-weight: 400; }
  .text-secondary { color: var(--color-dim-gray); }
  .mt-8 { margin-top: 8px; }
  .mt-16 { margin-top: 16px; }
  @media (max-width: 1024px) {
    .contact-list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .contact-list { grid-template-columns: 1fr; }
  }
</style>
