---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { filters, projects } from '../data/projects';

function countFor(filter: string) {
  if (filter === 'All') return projects.length;
  return projects.filter(project => project.category === filter).length;
}
---
<BaseLayout title="Projects | SupaKang" description="Projects by SupaKang.">
  <section class="project-board">
    <h1 class="sr-only">Projects</h1>

    <div class="project-controls">
      <div class="filter-bar" aria-label="Project categories">
        {filters.map((filter, index) => (
          <button
            type="button"
            class:list={['filter-button', { active: index === 0 }]}
            data-project-filter={filter}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            <span>{filter}</span>
            <span class="filter-count">{countFor(filter)}</span>
          </button>
        ))}
      </div>

      <label class="search-box" aria-label="Search projects">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m16.5 16.5 4 4"></path>
        </svg>
        <input type="search" placeholder="Search ..." data-project-search />
      </label>
    </div>

    <section class="project-grid" aria-label="Project list">
      {projects.map(project => (
        <ProjectCard project={project} filterable />
      ))}
    </section>

    <p class="empty-state" data-project-empty hidden>No matching projects.</p>
  </section>

  <script>
    const buttons = Array.from(document.querySelectorAll('[data-project-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-project-card]'));
    const emptyState = document.querySelector('[data-project-empty]');
    const searchInput = document.querySelector('[data-project-search]');
    let currentFilter = 'All';

    function applyFilters() {
      const query = searchInput instanceof HTMLInputElement
        ? searchInput.value.trim().toLocaleLowerCase()
        : '';
      let visibleCount = 0;

      cards.forEach((card) => {
        const category = card.getAttribute('data-category');
        const searchText = card.getAttribute('data-search') ?? '';
        const categoryMatch = currentFilter === 'All' || category === currentFilter;
        const searchMatch = query.length === 0 || searchText.includes(query);
        const isVisible = categoryMatch && searchMatch;

        card.toggleAttribute('hidden', !isVisible);
        if (isVisible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.toggleAttribute('hidden', visibleCount !== 0);
      }
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        currentFilter = button.getAttribute('data-project-filter') ?? 'All';

        buttons.forEach((item) => {
          const isActive = item === button;
          item.classList.toggle('active', isActive);
          item.setAttribute('aria-pressed', String(isActive));
        });

        applyFilters();
      });
    });

    searchInput?.addEventListener('input', applyFilters);
  </script>
</BaseLayout>

<style>
  .project-board {
    padding: 0 0 34px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .project-controls {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
    gap: 28px;
    align-items: center;
    margin: 0 0 28px;
  }

  .filter-bar {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 8px 0;
    scrollbar-width: none;
  }

  .filter-bar::-webkit-scrollbar {
    display: none;
  }

  .filter-button {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 18px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.64);
    color: var(--color-ink-soft);
    font: inherit;
    font-size: 15px;
    font-weight: 650;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(24, 25, 29, 0.04);
    transition: background 160ms ease, color 160ms ease, transform 160ms ease, border-color 160ms ease;
  }

  .filter-button:hover {
    transform: translateY(-1px);
    border-color: #cfd2d9;
  }

  .filter-button.active {
    color: #ffffff;
    border-color: var(--color-midnight-oil);
    background: var(--color-midnight-oil);
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    min-height: 22px;
    padding: 0 7px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.06);
    font-size: 12px;
  }

  .filter-button.active .filter-count {
    background: rgba(255, 255, 255, 0.16);
  }

  .search-box {
    min-height: 58px;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 0 22px;
    border-radius: 999px;
    background: #e7e7e9;
    color: var(--color-dim-gray);
  }

  .search-box svg {
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-box input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-midnight-oil);
    font: inherit;
    font-size: 17px;
  }

  .search-box input::placeholder {
    color: #a3a4aa;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: minmax(320px, auto);
    gap: 22px;
  }

  .empty-state {
    margin-top: 24px;
    padding: 24px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 22px;
    color: var(--color-dim-gray);
    background: #ffffff;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 1100px) {
    .project-controls {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .project-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 16px;
    }

    .filter-button {
      min-height: 44px;
      padding: 0 14px;
      font-size: 14px;
    }

    .search-box {
      min-height: 52px;
    }

  }
</style>
