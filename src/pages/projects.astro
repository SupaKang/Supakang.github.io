---
import BaseLayout from '../layouts/BaseLayout.astro';

const filters = ['All', 'Internal Tools', 'GIS / CAD', 'Public Work', 'Product'];

const projects = [
  {
    slug: 'hourly-rainfall-calculator',
    name: 'Hourly Rainfall Calculator',
    category: 'Internal Tools',
    meta: 'HRC | React / TypeScript / FastAPI / Python',
    visual: 'visual-rain',
  },
  {
    slug: 'sunlight-analysis',
    name: 'Sunlight Analysis',
    category: 'GIS / CAD',
    meta: 'SL | GIS / CAD-DXF / React / Firebase',
    visual: 'visual-sun',
  },
  {
    slug: 'slope-calculator',
    name: 'Slope Calculator',
    category: 'Internal Tools',
    meta: 'Slope | FastAPI / Python / Domain Logic',
    visual: 'visual-cad',
  },
  {
    slug: 'supablog',
    name: 'supablog',
    category: 'Product',
    meta: 'Astro / MDX / GitHub Pages',
    href: '/',
    visual: 'visual-ai',
  },
  {
    slug: 'subwayhero',
    name: 'SubwayHero',
    category: 'Public Work',
    meta: 'Product Prototype / UX',
    href: 'https://github.com/SupaKang/SubwayHero',
    external: true,
    visual: 'visual-workflow',
  },
  {
    slug: 'flixkookoo',
    name: 'FlixKooKoo',
    category: 'Public Work',
    meta: 'Movie Search · Watchlist',
    href: 'https://github.com/SupaKang/flixkookoo',
    external: true,
    visual: 'visual-system',
  },
  {
    slug: 'qr-generator',
    name: 'QR Generator',
    category: 'Public Work',
    meta: 'Browser Tool / QR',
    href: 'https://github.com/SupaKang/qr-generator',
    external: true,
    visual: 'visual-lilac',
  },
];

function countFor(filter: string) {
  if (filter === 'All') return projects.length;
  return projects.filter(project => project.category === filter).length;
}
---
<BaseLayout title="Projects | SupaKang" description="Projects by SupaKang.">
  <section class="project-board">
    <h1 class="sr-only">Projects</h1>

    <div class="project-controls">
      <div class="filter-bar" aria-label="Project categories">
        {filters.map((filter, index) => (
          <button
            type="button"
            class:list={['filter-button', { active: index === 0 }]}
            data-project-filter={filter}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            <span>{filter}</span>
            <span class="filter-count">{countFor(filter)}</span>
          </button>
        ))}
      </div>

      <label class="search-box" aria-label="Search projects">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m16.5 16.5 4 4"></path>
        </svg>
        <input type="search" placeholder="Search ..." data-project-search />
      </label>
    </div>

    <section class="project-grid" aria-label="Project list">
      {projects.map(project => (
        project.href ? (
          <a
            id={project.slug}
            href={project.href}
            class:list={['project-card', project.visual]}
            data-project-card
            data-category={project.category}
            data-search={`${project.name} ${project.category} ${project.meta}`.toLocaleLowerCase()}
            target={project.external ? '_blank' : undefined}
            rel={project.external ? 'noopener' : undefined}
          >
            <span class="card-category">{project.category}</span>
            <div class="visual-layer" aria-hidden="true">
              <span class="visual-chip chip-one"></span>
              <span class="visual-chip chip-two"></span>
              <span class="visual-chip chip-three"></span>
            </div>
            <div class="card-content">
              <h2>{project.name}</h2>
              <div class="card-meta">{project.meta}</div>
            </div>
          </a>
        ) : (
          <article
            id={project.slug}
            class:list={['project-card', project.visual]}
            data-project-card
            data-category={project.category}
            data-search={`${project.name} ${project.category} ${project.meta}`.toLocaleLowerCase()}
          >
            <span class="card-category">{project.category}</span>
            <div class="visual-layer" aria-hidden="true">
              <span class="visual-chip chip-one"></span>
              <span class="visual-chip chip-two"></span>
              <span class="visual-chip chip-three"></span>
            </div>
            <div class="card-content">
              <h2>{project.name}</h2>
              <div class="card-meta">{project.meta}</div>
            </div>
          </article>
        )
      ))}
    </section>

    <p class="empty-state" data-project-empty hidden>No matching projects.</p>
  </section>

  <script>
    const buttons = Array.from(document.querySelectorAll('[data-project-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-project-card]'));
    const emptyState = document.querySelector('[data-project-empty]');
    const searchInput = document.querySelector('[data-project-search]');
    let currentFilter = 'All';

    function applyFilters() {
      const query = searchInput instanceof HTMLInputElement
        ? searchInput.value.trim().toLocaleLowerCase()
        : '';
      let visibleCount = 0;

      cards.forEach((card) => {
        const category = card.getAttribute('data-category');
        const searchText = card.getAttribute('data-search') ?? '';
        const categoryMatch = currentFilter === 'All' || category === currentFilter;
        const searchMatch = query.length === 0 || searchText.includes(query);
        const isVisible = categoryMatch && searchMatch;

        card.toggleAttribute('hidden', !isVisible);
        if (isVisible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.toggleAttribute('hidden', visibleCount !== 0);
      }
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        currentFilter = button.getAttribute('data-project-filter') ?? 'All';

        buttons.forEach((item) => {
          const isActive = item === button;
          item.classList.toggle('active', isActive);
          item.setAttribute('aria-pressed', String(isActive));
        });

        applyFilters();
      });
    });

    searchInput?.addEventListener('input', applyFilters);
  </script>
</BaseLayout>

<style>
  .project-board {
    padding: 0 0 34px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .project-controls {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
    gap: 28px;
    align-items: center;
    margin: 0 0 28px;
  }

  .filter-bar {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 8px 0;
    scrollbar-width: none;
  }

  .filter-bar::-webkit-scrollbar {
    display: none;
  }

  .filter-button {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 18px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.64);
    color: var(--color-ink-soft);
    font: inherit;
    font-size: 15px;
    font-weight: 650;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(24, 25, 29, 0.04);
    transition: background 160ms ease, color 160ms ease, transform 160ms ease, border-color 160ms ease;
  }

  .filter-button:hover {
    transform: translateY(-1px);
    border-color: #cfd2d9;
  }

  .filter-button.active {
    color: #ffffff;
    border-color: var(--color-midnight-oil);
    background: var(--color-midnight-oil);
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    min-height: 22px;
    padding: 0 7px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.06);
    font-size: 12px;
  }

  .filter-button.active .filter-count {
    background: rgba(255, 255, 255, 0.16);
  }

  .search-box {
    min-height: 58px;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 0 22px;
    border-radius: 999px;
    background: #e7e7e9;
    color: var(--color-dim-gray);
  }

  .search-box svg {
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-box input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-midnight-oil);
    font: inherit;
    font-size: 17px;
  }

  .search-box input::placeholder {
    color: #a3a4aa;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: minmax(320px, auto);
    gap: 22px;
  }

  .project-card {
    position: relative;
    min-height: 320px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    border: 0;
    border-radius: 24px;
    color: #ffffff;
    background:
      linear-gradient(180deg, rgba(15, 18, 26, 0.06), rgba(5, 6, 9, 0.72)),
      var(--visual-base);
    box-shadow: 0 22px 48px rgba(24, 25, 29, 0.12);
    isolation: isolate;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 68px rgba(24, 25, 29, 0.18);
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(circle at 22% 18%, rgba(255, 255, 255, 0.28), transparent 24%),
      linear-gradient(125deg, rgba(255, 255, 255, 0.12), transparent 36%),
      var(--visual-base);
    transform: scale(1.02);
  }

  .project-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, transparent 25%, rgba(0, 0, 0, 0.42) 58%, rgba(0, 0, 0, 0.74) 100%),
      radial-gradient(circle at 70% 84%, rgba(49, 88, 245, 0.42), transparent 28%);
  }

  .visual-ai {
    --visual-base:
      linear-gradient(135deg, #3458ff 0%, #18243d 44%, #07090f 100%);
  }

  .visual-workflow {
    --visual-base:
      linear-gradient(135deg, #16a879 0%, #14373d 42%, #080c10 100%);
  }

  .visual-cad {
    --visual-base:
      linear-gradient(135deg, #13151d 0%, #365dd8 46%, #f1a33a 100%);
  }

  .visual-sun {
    --visual-base:
      linear-gradient(135deg, #ffbf48 0%, #df5c32 44%, #202126 100%);
  }

  .visual-rain {
    --visual-base:
      linear-gradient(135deg, #7cc7ff 0%, #3158f5 48%, #111827 100%);
  }

  .visual-system {
    --visual-base:
      linear-gradient(135deg, #7166ff 0%, #243048 46%, #08090f 100%);
  }

  .visual-lilac {
    --visual-base:
      linear-gradient(135deg, #8c7dff 0%, #3158f5 42%, #111827 100%);
  }

  .card-category {
    position: absolute;
    top: 22px;
    left: 22px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 13px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    color: #ffffff;
    font-size: 14px;
    font-weight: 650;
    backdrop-filter: blur(16px);
  }

  .visual-layer {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .visual-layer::before {
    content: "";
    position: absolute;
    inset: 18% -10% auto 42%;
    height: 36%;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 32px;
    transform: rotate(-12deg);
  }

  .visual-layer::after {
    content: "";
    position: absolute;
    right: 8%;
    top: 16%;
    width: 34%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.34), transparent 62%);
    filter: blur(2px);
  }

  .visual-chip {
    position: absolute;
    display: block;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }

  .chip-one {
    width: 44%;
    height: 10px;
    top: 24%;
    left: 12%;
    transform: rotate(-8deg);
  }

  .chip-two {
    width: 30%;
    height: 10px;
    top: 34%;
    left: 20%;
    transform: rotate(-8deg);
  }

  .chip-three {
    width: 54%;
    height: 10px;
    top: 44%;
    left: 8%;
    transform: rotate(-8deg);
  }

  .card-content {
    width: 100%;
    display: grid;
    gap: 16px;
    padding: 30px;
  }

  .card-content h2 {
    max-width: 760px;
    color: #ffffff;
    font-size: clamp(22px, 1.9vw, 30px);
    line-height: 1.08;
    text-wrap: balance;
  }

  .card-meta {
    color: rgba(255, 255, 255, 0.76);
    font-size: 15px;
    font-weight: 650;
  }

  .empty-state {
    margin-top: 24px;
    padding: 24px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 22px;
    color: var(--color-dim-gray);
    background: #ffffff;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 1100px) {
    .project-controls {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .project-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 16px;
    }

    .project-card {
      min-height: 360px;
    }

    .filter-button {
      min-height: 44px;
      padding: 0 14px;
      font-size: 14px;
    }

    .search-box {
      min-height: 52px;
    }

    .card-content {
      padding: 24px;
    }
  }
</style>
