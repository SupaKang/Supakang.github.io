---
import BaseLayout from '../layouts/BaseLayout.astro';

const contactLinks = [
  { label: 'Email', value: 'seankangster@gmail.com', href: 'mailto:seankangster@gmail.com' },
  { label: 'X', value: '@supakng1996', href: 'https://twitter.com/supakng1996' },
  { label: 'LinkedIn', value: 'Sunku Kang', href: 'https://www.linkedin.com/in/sunku-kang-7b549927b/' },
  { label: 'GitHub', value: 'SupaKang', href: 'https://github.com/SupaKang' },
];

const backgroundParagraphs = [
  'I started in interior architecture and design, where I learned how people move through space, how visual structure affects behavior, and how to design around real user contexts.',
  'That background naturally led me into web and app design, then into software development. Over time, I moved from designing interfaces to building actual systems - web applications, internal tools, automation programs, and GIS-related add-ons and plugins.',
  'I also spent over three years as a full-time researcher in a graduate research lab, working on national smart city R&D projects. There, I worked across service planning, living lab operations, user research, data-driven problem solving, and citizen-facing digital services.',
  'Today, I combine these experiences into a single direction: building useful software through product thinking, design sensitivity, full-stack execution, and AI-native workflows.',
];

const strengths = [
  {
    title: 'Product Thinking',
    body: [
      'I turn ambiguous problems into clear product requirements.',
      'My experience in service planning, user research, R&D documentation, and stakeholder collaboration helps me break down complex problems into goals, users, features, priorities, and implementation scopes.',
      'I care about whether an idea can actually become a working product - not just whether it looks good in a document.',
    ],
  },
  {
    title: 'Full-Stack Development',
    body: [
      'I build working software from idea to implementation.',
      'I work with modern web technologies such as React, TypeScript, Firebase, Supabase, and API-based architectures. Beyond web services, I also build practical software systems including automation tools, internal operation tools, and GIS program add-ons and plugins.',
      'My focus is not limited to a specific format of software. I choose the right technical shape for the problem.',
    ],
  },
  {
    title: 'Design & UX',
    body: [
      'I design interfaces with structure, flow, and usability in mind.',
      'My design background helps me think beyond visual styling. I care about how users understand information, move through a product, and complete tasks with minimal friction.',
      'I see design as a structural part of product building - not decoration added at the end.',
    ],
  },
  {
    title: 'AI Workflow Engineering',
    body: [
      'I build workflows where AI becomes part of the development process.',
      'I use AI systems for planning, coding, reviewing, testing, and documenting software. By separating roles across different models and agents, I create workflows that support better iteration, clearer reasoning, and faster delivery.',
      'The goal is not to replace engineering judgment. The goal is to build better engineering systems around it.',
    ],
  },
  {
    title: 'Research-Driven Execution',
    body: [
      'I connect technology, users, and real-world contexts.',
      'Through smart city, IoT, living lab, and public R&D projects, I have worked on problems that required both field understanding and technical execution.',
      'This experience helps me approach software not only as code, but as a system used by real people in real environments.',
    ],
  },
];

const career = [
  {
    company: 'Korea Construction Environment Co., Ltd.',
    role: 'Researcher',
    period: '2025 - Present',
    summary: 'Working on automation software development and AI integration for internal workflows. Focus areas include process automation, data handling, AI-assisted work systems, and practical software tools for engineering and environmental analysis workflows.',
  },
  {
    company: 'Oddloop',
    role: 'Freelance Designer & Developer',
    period: '2018 - Present',
    summary: 'Built websites, design assets, branding materials, and client-facing digital products. Worked across visual design, web implementation, presentation materials, and small business digital production.',
  },
];

const education = [
  {
    school: 'Yonsei University Graduate School of Information',
    degree: 'M.S. in Information Systems',
    period: '2022 - 2025',
    grade: '3.87 / 4.3',
    courses: [
      'IoT service platforms',
      'IoT analytics and AI',
      'AI-based IoT optimization',
      'IT entrepreneurship and IoT innovation',
      'Smart city service planning',
      'Human-centered technology research',
    ],
  },
  {
    school: 'Academic Credit Bank System',
    degree: 'B.S. in Information and Communication Engineering',
    period: '2020 - 2021',
    grade: '3.8 / 4.5',
    courses: [
      'C programming',
      'Data structures',
      'Computer networks',
      'Microprocessors',
      'Information and communication systems',
    ],
  },
  {
    school: 'Hansei University',
    degree: 'Interior Architecture Design',
    period: '2016 - 2020',
    grade: '3.3 / 4.5',
    status: 'Incomplete',
    courses: [
      'Interior design',
      'Furniture design',
      '3D computer-aided design',
      'Spatial planning',
      'Upcycling design',
    ],
  },
];

const briefs = [
  { title: 'Product Builder', line: 'I structure problems and turn them into buildable product systems.' },
  { title: 'Full-Stack Developer', line: 'I build web services, automation tools, internal systems, and GIS-related plugins.' },
  { title: 'Designer', line: 'I design user flows, interfaces, and information structures with clarity.' },
  { title: 'PM-Oriented Planner', line: 'I define requirements, priorities, scopes, and execution plans.' },
  { title: 'AI Workflow Engineer', line: 'I integrate AI into planning, implementation, review, testing, and documentation workflows.' },
  { title: 'Technical Storyteller', line: 'I turn complex projects into clear documents, presentations, and technical writing.' },
];
---
<BaseLayout
  title="About | SupaKang"
  description="Sunku Kang, AI-native product builder profile."
>
  <section class="about-hero">
    <div class="hero-copy">
      <div class="eyebrow">About Me</div>
      <h1 class="hero-title">
        <span>AI-Native</span>
        <span>Product Builder</span>
      </h1>
      <p>
        I design and build practical software with AI as part of the engineering system.
      </p>
      <p>
        My work sits at the intersection of product thinking, full-stack development, design,
        and AI-assisted engineering. I use AI not just as a productivity tool, but as an
        integrated layer in the development workflow - from problem framing and system design
        to implementation, review, testing, and documentation.
      </p>
    </div>

    <aside class="contact-panel" aria-label="Contact">
      <h2>Contact</h2>
      <div class="contact-grid">
        {contactLinks.map(link => (
          <a
            href={link.href}
            class="contact-link"
            target={link.href.startsWith('mailto:') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto:') ? undefined : 'noopener'}
          >
            <span>{link.label}</span>
            <strong>{link.value}</strong>
          </a>
        ))}
      </div>
    </aside>
  </section>

  <section class="section profile-section">
    <div class="section-heading">
      <span>Background</span>
      <h2>Design, research, and software execution</h2>
    </div>

    <div class="profile-card">
      {backgroundParagraphs.map(paragraph => (
        <p>{paragraph}</p>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span>Core Strengths</span>
      <h2>How I build</h2>
    </div>

    <div class="strength-grid">
      {strengths.map(item => (
        <article class="strength-card">
          <h3>{item.title}</h3>
          {item.body.map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span>Career</span>
      <h2>Work experience</h2>
    </div>

    <div class="info-grid two-column">
      {career.map(item => (
        <article class="info-card">
          <div class="card-top">
            <span>{item.period}</span>
          </div>
          <h3>{item.company}</h3>
          <p class="role">{item.role}</p>
          <p class="detail">{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span>Education</span>
      <h2>Academic background</h2>
    </div>

    <div class="info-grid">
      {education.map(item => (
        <article class="info-card education-card">
          <div class="card-top">
            <span>{item.period}</span>
            <span>GPA {item.grade}</span>
          </div>
          <h3>{item.school}</h3>
          <p class="role">
            {item.degree}{item.status ? `, ${item.status}` : ''}
          </p>
          <ul class="course-list">
            {item.courses.map(course => (
              <li>{course}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span>Career Brief</span>
      <h2>Working identity</h2>
    </div>

    <div class="brief-grid">
      {briefs.map(item => (
        <article class="brief-card">
          <h3>{item.title}</h3>
          <p>{item.line}</p>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  .about-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 410px);
    gap: 28px;
    align-items: stretch;
    margin: 22px 0 86px;
  }

  .hero-copy {
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 34px 0;
  }

  .eyebrow,
  .section-heading span {
    color: var(--color-signal-cyan);
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
  }

  h1 {
    max-width: 920px;
    margin-top: 14px;
    font-size: clamp(44px, 6vw, 82px);
    line-height: 1.03;
  }

  .hero-title {
    display: grid;
    gap: 10px;
  }

  .hero-title span {
    display: block;
  }

  .hero-copy p {
    max-width: 780px;
    margin-top: 22px;
    color: var(--color-dim-gray);
    font-size: 18px;
    line-height: 1.72;
  }

  .contact-panel,
  .profile-card,
  .info-card,
  .brief-card,
  .strength-card {
    border: 1px solid var(--color-muted-ash);
    background: #ffffff;
    box-shadow: 0 18px 44px rgba(24, 25, 29, 0.06);
  }

  .contact-panel {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 28px;
    border-radius: 28px;
  }

  .contact-panel h2 {
    font-size: 24px;
  }

  .contact-grid {
    display: grid;
    gap: 12px;
    margin-top: 32px;
  }

  .contact-link {
    display: grid;
    gap: 6px;
    min-height: 78px;
    padding: 16px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 18px;
    background: var(--color-shell);
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .contact-link:hover {
    transform: translateY(-2px);
    border-color: var(--color-signal-cyan);
    background: var(--color-midnight-oil);
  }

  .contact-link span {
    color: var(--color-dim-gray);
    font-size: 13px;
    font-weight: 750;
    transition: color 160ms ease;
  }

  .contact-link strong {
    color: var(--color-midnight-oil);
    font-size: 15px;
    word-break: break-word;
    transition: color 160ms ease;
  }

  .contact-link:hover span,
  .contact-link:hover strong {
    color: #ffffff;
  }

  .section {
    margin: 96px 0;
  }

  .section-heading {
    display: grid;
    gap: 8px;
    margin-bottom: 20px;
  }

  .section-heading h2 {
    font-size: clamp(26px, 3vw, 38px);
  }

  .profile-card {
    display: grid;
    gap: 18px;
    padding: 30px;
    border-radius: 28px;
    color: var(--color-ink-soft);
    font-size: 17px;
    line-height: 1.85;
  }

  .profile-card p {
    margin: 0;
  }

  .strength-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .strength-card {
    display: grid;
    align-content: start;
    gap: 14px;
    min-height: 320px;
    padding: 24px;
    border-radius: 24px;
  }

  .strength-card h3 {
    font-size: 24px;
  }

  .strength-card p {
    color: var(--color-dim-gray);
    line-height: 1.72;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .info-grid.two-column {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .info-card {
    display: grid;
    align-content: start;
    gap: 14px;
    min-height: 280px;
    padding: 24px;
    border-radius: 24px;
  }

  .education-card {
    min-height: 360px;
  }

  .card-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 10px;
    color: var(--color-signal-cyan);
    font-size: 13px;
    font-weight: 800;
  }

  .info-card h3 {
    font-size: 22px;
  }

  .role {
    color: var(--color-midnight-oil);
    font-weight: 800;
  }

  .detail {
    color: var(--color-dim-gray);
    line-height: 1.7;
  }

  .course-list {
    margin: 0;
    padding-left: 0;
    color: var(--color-dim-gray);
    line-height: 1.62;
    list-style: none;
  }

  .course-list li {
    position: relative;
    margin: 6px 0;
    padding-left: 18px;
  }

  .course-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.68em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-signal-cyan);
    box-shadow: 0 0 0 4px rgba(49, 88, 245, 0.12);
  }

  .brief-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .brief-card {
    min-height: 170px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 10px;
    padding: 22px;
    border-radius: 24px;
  }

  .brief-card h3 {
    font-size: 24px;
  }

  .brief-card p {
    color: var(--color-dim-gray);
    font-size: 15px;
    line-height: 1.65;
  }

  @media (max-width: 1100px) {
    .about-hero,
    .info-grid,
    .info-grid.two-column,
    .brief-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-copy {
      grid-column: 1 / -1;
      min-height: 320px;
    }
  }

  @media (max-width: 860px) {
    .strength-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .about-hero,
    .info-grid,
    .info-grid.two-column,
    .brief-grid {
      grid-template-columns: 1fr;
    }

    .about-hero {
      margin-bottom: 64px;
    }

    .section {
      margin: 72px 0;
    }

    .hero-copy {
      min-height: 260px;
      padding: 18px 0;
    }

    h1 {
      font-size: 38px;
    }

    .hero-copy p,
    .profile-card {
      font-size: 16px;
    }

    .info-card,
    .brief-card,
    .strength-card,
    .education-card {
      min-height: 0;
    }

  }
</style>
