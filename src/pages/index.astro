---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const featuredProjectSlugs = new Set([
  'hourly-rainfall-calculator',
  'sunlight-analysis',
  'slope-calculator',
]);
const internalProducts = projects.filter(project => featuredProjectSlugs.has(project.slug));
const postVisuals = ['visual-ai', 'visual-workflow', 'visual-cad', 'visual-sun'];
const decoratedPosts = posts.map((post, index) => ({
  post,
  visual: postVisuals[index % postVisuals.length],
}));

---
<BaseLayout
  title="SupaKang | AI-native product log"
  description="AI-native product builder working on internal construction and environmental engineering tools."
>
  <section class="hero">
    <div class="hero-copy">
      <div class="eyebrow">AI-native product builder</div>
      <h1>Turning domain workflows into internal software.</h1>
      <p class="hero-lede text-secondary">
        I build practical tools for construction and environmental engineering as a full-stack developer,
        integrating multi-agent AI workflows.
      </p>
    </div>

    <aside class="hero-panel surface-card" aria-label="Current build focus">
      <div class="panel-copy">
        <div class="panel-kicker">Current system</div>
        <div class="panel-title">Internal workflow tools</div>
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <div class="eyebrow">Internal products</div>
        <h2>Built around real office work</h2>
      </div>
      <a href="/projects/" class="section-link">All projects</a>
    </div>

    <div class="product-grid">
      {internalProducts.map(project => (
        <ProjectCard project={project} href={`/projects/#${project.slug}`} headingLevel="h3" />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <div class="eyebrow">Articles and Insights</div>
        <h2>Articles and Insights</h2>
      </div>
      <a href="/blog/" class="section-link">All posts</a>
    </div>

    {posts.length === 0 ? (
      <p class="text-secondary">No posts yet.</p>
    ) : (
      <div class="post-grid">
        {decoratedPosts.map(({ post, visual }) => (
          <PostCard post={post} visual={visual} headingLevel="h3" />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
    gap: 30px;
    align-items: stretch;
    margin: 36px 0 86px;
  }

  .hero-copy {
    min-height: 390px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 36px 0;
  }

  .eyebrow {
    margin-bottom: 12px;
    color: var(--color-signal-cyan);
    font-size: 13px;
    font-weight: 750;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 860px;
    font-size: clamp(42px, 5vw, 76px);
    letter-spacing: 0;
  }

  .hero-lede {
    max-width: 760px;
    margin-top: 20px;
    font-size: 18px;
  }

  .hero-panel {
    position: relative;
    overflow: hidden;
    min-height: 430px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #ffffff;
    border: 0;
    background:
      linear-gradient(180deg, rgba(8, 12, 18, 0.08), rgba(8, 12, 18, 0.72)),
      url("https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=900&q=80") center / cover no-repeat;
    box-shadow: 0 26px 58px rgba(24, 25, 29, 0.15);
    isolation: isolate;
  }

  .panel-copy {
    max-width: 260px;
  }

  .panel-kicker {
    color: rgba(255, 255, 255, 0.72);
    font-size: 13px;
    font-weight: 750;
    text-transform: uppercase;
  }

  .panel-title {
    margin-top: 12px;
    font-size: 24px;
    line-height: 1.2;
  }

  .section {
    margin: 90px 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    margin-bottom: 20px;
  }

  .section-link {
    color: var(--color-signal-cyan);
    font-weight: 750;
    font-size: 14px;
  }

  .product-grid,
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .post-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (max-width: 980px) {
    .hero,
    .product-grid,
    .post-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      min-height: 300px;
    }

    .hero h1 {
      font-size: 40px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      margin: 32px 0 68px;
    }

    .section {
      margin: 72px 0;
    }

    .hero h1 {
      font-size: 32px;
    }

    .hero-lede {
      font-size: 16px;
    }

    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
