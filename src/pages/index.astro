---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const internalProducts = [
  {
    slug: 'hourly-rainfall-calculator',
    name: 'Hourly Rainfall Calculator',
    domain: 'Hydrology / rainfall review',
    stack: 'React, TypeScript, FastAPI, Python',
    impact: 'Input standardization, fewer manual steps, lower human-error risk',
  },
  {
    slug: 'sunlight-analysis',
    name: 'Sunlight Analysis',
    domain: 'Sunlight / GIS / CAD workflow',
    stack: 'React, TypeScript, GIS, CAD/DXF, Firebase',
    impact: 'Structured input flow and repeatable analysis workflow',
  },
  {
    slug: 'slope-calculator',
    name: 'Slope Calculator',
    domain: 'Slope review / engineering calculation',
    stack: 'React, FastAPI, Python, domain logic',
    impact: 'Internalized paid-tool workflow and reduced repeated calculation work',
  },
];

const focusAreas = [
  { label: 'AI Workflow', value: 'Design, code, test, docs, review' },
  { label: 'Domain Software', value: 'Construction and environmental workflows' },
  { label: 'Internal Tools', value: 'Private products built for real office work' },
];
---
<BaseLayout
  title="SupaKang | AI-native product log"
  description="AI-native product builder working on internal construction and environmental engineering tools."
>
  <section class="hero">
    <div class="hero-copy">
      <div class="eyebrow">AI-native product builder</div>
      <h1>Turning domain workflows into internal software.</h1>
      <p class="hero-lede text-secondary">
        I build practical tools for construction and environmental engineering work with React, TypeScript,
        FastAPI, Python, GIS/CAD data, Firebase, and multi-agent AI workflows.
      </p>
      <div class="hero-actions">
        <a href="/blog/" class="btn-ghost">Read build logs</a>
        <a href="/projects/" class="btn-ghost">View projects</a>
      </div>
    </div>

    <aside class="hero-panel surface-card" aria-label="Current build focus">
      <div class="panel-kicker">Current system</div>
      <div class="panel-title">Internal workflow tools</div>
      <div class="panel-grid">
        {focusAreas.map(item => (
          <div class="focus-row">
            <span class="focus-label">{item.label}</span>
            <span class="focus-value">{item.value}</span>
          </div>
        ))}
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <div class="eyebrow">Internal products</div>
        <h2>Built around real office work</h2>
      </div>
      <a href="/projects/" class="section-link">All projects</a>
    </div>

    <div class="product-grid">
      {internalProducts.map((product, index) => (
        <a href={`/projects/#${product.slug}`} class="product-card surface-card">
          <div class="product-index">0{index + 1}</div>
          <h3>{product.name}</h3>
          <p class="text-secondary">{product.domain}</p>
          <div class="meta-stack">
            <span class="pill cyan">{product.stack}</span>
          </div>
          <p class="impact">{product.impact}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <div class="eyebrow">Latest writing</div>
        <h2>Build logs and workflow notes</h2>
      </div>
      <a href="/blog/" class="section-link">All posts</a>
    </div>

    {posts.length === 0 ? (
      <p class="text-secondary">No posts yet.</p>
    ) : (
      <div class="post-grid">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="post-card surface-card">
            <div class="post-meta">
              <span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
              <span class="pill orange">{post.data.category}</span>
            </div>
            <h3>{post.data.title}</h3>
            <p class="text-secondary">{post.data.description}</p>
            <div class="post-footer">
              <span>{post.data.readMin ?? '-'} min read</span>
              {post.data.project && <span>{post.data.project}</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
    gap: 30px;
    align-items: stretch;
    margin: 36px 0 62px;
  }

  .hero-copy {
    min-height: 390px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 36px 0;
  }

  .eyebrow {
    margin-bottom: 12px;
    color: var(--color-signal-cyan);
    font-size: 13px;
    font-weight: 750;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 860px;
    font-size: clamp(42px, 5vw, 76px);
    letter-spacing: 0;
  }

  .hero-lede {
    max-width: 760px;
    margin-top: 20px;
    font-size: 18px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .hero-panel {
    position: relative;
    overflow: hidden;
    min-height: 430px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: #ffffff;
    border: 0;
    background:
      linear-gradient(180deg, rgba(20, 22, 30, 0.06), rgba(5, 7, 12, 0.72)),
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.42), transparent 19%),
      linear-gradient(135deg, #3158f5 0%, #18253e 46%, #07090f 100%);
    box-shadow: 0 26px 58px rgba(24, 25, 29, 0.15);
    isolation: isolate;
  }

  .hero-panel::before {
    content: "";
    position: absolute;
    inset: 20% -14% auto 36%;
    height: 34%;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 34px;
    transform: rotate(-13deg);
    z-index: -1;
  }

  .hero-panel::after {
    content: "";
    position: absolute;
    right: 10%;
    top: 14%;
    width: 38%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.36), transparent 62%);
    z-index: -1;
  }

  .panel-kicker {
    color: rgba(255, 255, 255, 0.72);
    font-size: 13px;
    font-weight: 750;
    text-transform: uppercase;
  }

  .panel-title {
    margin-top: 12px;
    font-size: 24px;
    line-height: 1.2;
  }

  .panel-grid {
    display: grid;
    gap: 12px;
    margin-top: 32px;
  }

  .focus-row {
    padding: 14px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
  }

  .focus-label,
  .focus-value {
    display: block;
  }

  .focus-label {
    color: #b8ffdc;
    font-size: 13px;
  }

  .focus-value {
    margin-top: 6px;
    color: #ffffff;
    font-size: 14px;
  }

  .section {
    margin: 64px 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    margin-bottom: 20px;
  }

  .section-link {
    color: var(--color-signal-cyan);
    font-weight: 750;
    font-size: 14px;
  }

  .product-grid,
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .post-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .product-card,
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 240px;
    padding: 22px;
    border-bottom: 1px solid var(--color-muted-ash);
  }

  .product-card:hover,
  .post-card:hover {
    transform: translateY(-3px);
    border-color: rgba(49, 88, 245, 0.28);
    background: #ffffff;
    box-shadow: 0 26px 54px rgba(24, 25, 29, 0.1);
  }

  .product-index {
    color: var(--color-accent-orange);
    font-size: 13px;
  }

  .meta-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .impact {
    margin-top: auto;
    color: var(--color-terrain-green);
    font-weight: 700;
    font-size: 14px;
  }

  .post-meta,
  .post-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    color: var(--color-dim-gray);
    font-size: 13px;
  }

  .post-footer {
    margin-top: auto;
    justify-content: space-between;
  }

  @media (max-width: 980px) {
    .hero,
    .product-grid,
    .post-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      min-height: 300px;
    }

    .hero h1 {
      font-size: 40px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      margin-top: 32px;
    }

    .hero h1 {
      font-size: 32px;
    }

    .hero-lede {
      font-size: 16px;
    }

    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
