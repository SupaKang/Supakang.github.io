---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { data } = post;
---
<BaseLayout title={`${data.title} | supablog`} description={data.description}>
  <article class="post">
    <header class="post-header">
      <div class="meta">
        <time datetime={data.pubDate.toISOString()}>{data.pubDate.toISOString().slice(0, 10)}</time>
        {data.project && <span class="project-tag">{data.project}</span>}
        <span class="text-secondary">{data.readMin ?? '–'}분 읽기</span>
      </div>
      <h1 class="title mt-16">{data.title}</h1>
      <p class="lede text-secondary mt-16">{data.description}</p>
      {data.tags.length > 0 && (
        <div class="tags mt-16">
          {data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="content mt-32">
      <Content />
    </div>

    {data.notionUrl && (
      <footer class="post-footer mt-32">
        <div class="text-secondary">
          source devlog: <code>{data.sourceDevlog}</code>
        </div>
        <div class="text-secondary mt-8">
          notion mirror: <a href={data.notionUrl} target="_blank" rel="noopener">{data.notionUrl}</a>
        </div>
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 720px;
    margin: 48px auto;
  }
  .post-header {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-muted-ash);
  }
  .meta {
    display: flex;
    gap: 16px;
    align-items: center;
    font-size: 14px;
  }
  .project-tag {
    padding: 5px 8px;
    background: var(--color-steel-gray);
    border-radius: 10px;
    font-size: 14px;
  }
  .title {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
  }
  .lede {
    font-size: 16px;
    line-height: 1.4;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    padding: 5px 8px;
    background: var(--color-steel-gray);
    border-radius: 10px;
    font-size: 14px;
    color: var(--color-dim-gray);
  }
  .content {
    font-size: 16px;
    line-height: 1.4;
  }
  .content :global(h2),
  .content :global(h3),
  .content :global(h4) {
    margin-top: 32px;
    margin-bottom: 16px;
  }
  .content :global(p) {
    margin: 16px 0;
  }
  .content :global(pre) {
    background: var(--color-steel-gray);
    padding: 19px 26px;
    border-radius: 10px;
    overflow-x: auto;
    margin: 16px 0;
  }
  .post-footer {
    padding-top: 32px;
    border-top: 1px solid var(--color-muted-ash);
    font-size: 14px;
  }
  .text-secondary { color: var(--color-dim-gray); }
  .mt-8 { margin-top: 8px; }
  .mt-16 { margin-top: 16px; }
  .mt-32 { margin-top: 32px; }
</style>
