---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { data } = post;

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = allPosts.findIndex(item => item.id === post.id);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : undefined;
const relatedPosts = allPosts
  .filter(item => item.id !== post.id)
  .filter(item => item.data.category === data.category || (data.project && item.data.project === data.project))
  .slice(0, 3);
---
<BaseLayout title={`${data.title} | SupaKang`} description={data.description}>
  <article class="post-shell">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/blog/">Blog</a>
      <span>/</span>
      <span>{data.category}</span>
    </nav>

    <header class="post-header">
      <div class="meta">
        <time datetime={data.pubDate.toISOString()}>{data.pubDate.toISOString().slice(0, 10)}</time>
        <span class="pill orange">{data.category}</span>
        {data.project && <span class="pill cyan">{data.project}</span>}
        <span class="pill">{data.readMin ?? '-'} min read</span>
      </div>
      <h1>{data.title}</h1>
      <p class="lede text-secondary">{data.description}</p>
      {data.tags.length > 0 && (
        <div class="tags">
          {data.tags.map(tag => <span class="pill green">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="post-visual" aria-hidden="true">
      <span class="visual-badge">{data.category}</span>
      <span class="visual-line line-one"></span>
      <span class="visual-line line-two"></span>
      <span class="visual-line line-three"></span>
    </div>

    <div class="post-layout">
      <aside class="post-side" aria-label="Post actions">
        <a href="/blog/" class="side-link">Back to Blog</a>
        {data.sourceDevlog && <span class="side-note">Source: {data.sourceDevlog}</span>}
      </aside>

      <div class="content">
        <Content />
      </div>
    </div>

    {data.notionUrl && (
      <footer class="source-footer">
        <div>
          <span class="text-secondary">Notion mirror</span>
          <a href={data.notionUrl} target="_blank" rel="noopener">{data.notionUrl}</a>
        </div>
      </footer>
    )}

    <nav class="adjacent-posts" aria-label="Adjacent posts">
      {olderPost ? (
        <a href={`/blog/${olderPost.id}/`} class="adjacent-card surface-card">
          <span class="text-secondary">Previous</span>
          <strong>{olderPost.data.title}</strong>
        </a>
      ) : (
        <div class="adjacent-card disabled surface-card">
          <span class="text-secondary">Previous</span>
          <strong>No older post</strong>
        </div>
      )}

      {newerPost ? (
        <a href={`/blog/${newerPost.id}/`} class="adjacent-card surface-card align-right">
          <span class="text-secondary">Next</span>
          <strong>{newerPost.data.title}</strong>
        </a>
      ) : (
        <div class="adjacent-card disabled surface-card align-right">
          <span class="text-secondary">Next</span>
          <strong>Latest post</strong>
        </div>
      )}
    </nav>

    {relatedPosts.length > 0 && (
      <section class="related-section">
        <div class="section-kicker">Related notes</div>
        <div class="related-grid">
          {relatedPosts.map(item => (
            <a href={`/blog/${item.id}/`} class="related-card surface-card">
              <span class="pill orange">{item.data.category}</span>
              <h2>{item.data.title}</h2>
              <p class="text-secondary">{item.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .post-shell {
    max-width: 1120px;
    margin: 28px auto 72px;
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    color: var(--color-dim-gray);
    font-size: 13px;
    margin-bottom: 28px;
  }

  .breadcrumb a {
    color: var(--color-signal-cyan);
    font-weight: 750;
  }

  .post-header {
    max-width: 860px;
    padding-bottom: 34px;
    border-bottom: 1px solid var(--color-muted-ash);
  }

  .meta,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .meta {
    color: var(--color-dim-gray);
    font-size: 13px;
  }

  .post-header h1 {
    margin-top: 18px;
    font-size: clamp(34px, 4.6vw, 58px);
  }

  .lede {
    margin-top: 18px;
    font-size: 17px;
  }

  .tags {
    margin-top: 18px;
  }

  .post-visual {
    position: relative;
    min-height: 320px;
    margin: 34px 0 0;
    overflow: hidden;
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(20, 22, 30, 0.08), rgba(5, 7, 12, 0.72)),
      radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.42), transparent 20%),
      linear-gradient(135deg, #3158f5 0%, #18253e 46%, #07090f 100%);
    box-shadow: 0 26px 58px rgba(24, 25, 29, 0.14);
  }

  .post-visual::before {
    content: "";
    position: absolute;
    inset: 22% -8% auto 44%;
    height: 35%;
    border: 1px solid rgba(255, 255, 255, 0.27);
    border-radius: 34px;
    transform: rotate(-13deg);
  }

  .post-visual::after {
    content: "";
    position: absolute;
    right: 11%;
    top: 15%;
    width: 27%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.36), transparent 62%);
  }

  .visual-badge {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    color: #ffffff;
    font-size: 14px;
    font-weight: 750;
    backdrop-filter: blur(16px);
  }

  .visual-line {
    position: absolute;
    left: 9%;
    height: 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.24);
    transform: rotate(-8deg);
  }

  .line-one {
    width: 40%;
    top: 38%;
  }

  .line-two {
    width: 28%;
    top: 48%;
    left: 16%;
  }

  .line-three {
    width: 50%;
    top: 58%;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 760px);
    gap: 48px;
    align-items: start;
    margin-top: 40px;
  }

  .post-side {
    position: sticky;
    top: 96px;
    display: grid;
    gap: 14px;
    color: var(--color-dim-gray);
    font-size: 13px;
  }

  .side-link {
    width: fit-content;
    color: var(--color-signal-cyan);
    font-weight: 750;
  }

  .side-note {
    display: block;
    line-height: 1.5;
  }

  .content {
    padding: 34px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 18px 44px rgba(24, 25, 29, 0.06);
    font-size: 16px;
    line-height: 1.75;
  }

  .content :global(h2),
  .content :global(h3),
  .content :global(h4) {
    margin-top: 40px;
    margin-bottom: 14px;
  }

  .content :global(h2) {
    font-size: 24px;
    color: var(--color-ghost-white);
  }

  .content :global(h3) {
    font-size: 19px;
    color: var(--color-signal-cyan);
  }

  .content :global(p) {
    margin: 18px 0;
  }

  .content :global(a) {
    color: var(--color-signal-cyan);
  }

  .content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-muted-ash);
  }

  .source-footer {
    margin-top: 44px;
    padding-top: 20px;
    border-top: 1px solid var(--color-muted-ash);
    font-size: 13px;
  }

  .source-footer div {
    display: grid;
    gap: 6px;
  }

  .source-footer a {
    color: var(--color-signal-cyan);
    word-break: break-all;
  }

  .adjacent-posts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 44px;
  }

  .adjacent-card {
    display: grid;
    gap: 8px;
    padding: 18px;
  }

  .adjacent-card:hover {
    border-color: rgba(49, 88, 245, 0.28);
    background: #ffffff;
    transform: translateY(-2px);
  }

  .adjacent-card strong {
    font-size: 15px;
    font-weight: 500;
  }

  .adjacent-card.disabled {
    opacity: 0.45;
  }

  .align-right {
    text-align: right;
  }

  .related-section {
    margin-top: 54px;
  }

  .section-kicker {
    margin-bottom: 14px;
    color: var(--color-signal-cyan);
    font-weight: 750;
    font-size: 13px;
    text-transform: uppercase;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .related-card {
    display: grid;
    gap: 12px;
    padding: 18px;
  }

  .related-card:hover {
    border-color: rgba(49, 88, 245, 0.28);
    background: #ffffff;
    transform: translateY(-2px);
  }

  .related-card h2 {
    font-size: 17px;
  }

  .related-card p {
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .post-layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .post-side {
      position: static;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
    }

    .related-grid,
    .adjacent-posts {
      grid-template-columns: 1fr;
    }

    .align-right {
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    .post-shell {
      margin-top: 32px;
    }

    .post-header h1 {
      font-size: 30px;
    }

    .post-visual {
      min-height: 230px;
      border-radius: 22px;
    }

    .content {
      padding: 24px 18px;
      border-radius: 20px;
    }
  }
</style>
