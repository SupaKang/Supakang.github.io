---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog | supablog" description="모든 글 목록 — devlog 자동 변환 회고">
  <section class="section">
    <h1>Blog</h1>
    <p class="text-secondary mt-16">{posts.length}개 글 · 최근 게시순</p>
  </section>

  <section class="section">
    {posts.length === 0 ? (
      <p class="text-secondary">아직 게시된 글이 없습니다.</p>
    ) : (
      <div class="post-list">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-meta">
              <span class="text-secondary">{post.data.pubDate.toISOString().slice(0, 10)}</span>
              {post.data.project && <span class="project-tag">{post.data.project}</span>}
              <span class="text-secondary">{post.data.readMin ?? '–'}분</span>
            </div>
            <h2 class="post-title mt-8">{post.data.title}</h2>
            <p class="text-secondary mt-8">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-tags mt-16">
                {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .section { margin: 48px 0; }
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .post-card {
    padding: 26px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-ghost-white);
    border-bottom: 1px solid var(--color-muted-ash);
    display: block;
    transition: background 120ms ease;
  }
  .post-card:hover { background: var(--color-steel-gray); }
  .post-meta {
    display: flex;
    gap: 16px;
    font-size: 14px;
    align-items: center;
  }
  .project-tag {
    padding: 5px 8px;
    background: var(--color-steel-gray);
    border-radius: 10px;
    font-size: 14px;
  }
  .post-title {
    font-size: 16px;
    font-weight: 400;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    padding: 5px 8px;
    background: var(--color-steel-gray);
    border-radius: 10px;
    font-size: 14px;
    color: var(--color-dim-gray);
  }
  .text-secondary { color: var(--color-dim-gray); }
  .mt-8 { margin-top: 8px; }
  .mt-16 { margin-top: 16px; }
</style>
