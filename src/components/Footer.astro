---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-row">
    <div>© {year} Sean Kang</div>
    <div class="text-secondary">supablog · Astro + 099 design</div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-muted-ash);
    padding: 32px 0;
    margin-top: 48px;
  }
  .footer-row {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 26px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 14px;
  }
  .text-secondary {
    color: var(--color-dim-gray);
  }
</style>
