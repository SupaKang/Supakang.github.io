---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---
<header class="site-header">
  <div class="header-row">
    <a href="/" class="brand" aria-label="Go to home">
      <span class="brand-name">SUPA</span>
    </a>

    <nav class="nav-row" aria-label="Primary navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/contact/" class="language-pill" aria-label="Open contact page">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M3 12h18M12 3c2.4 2.7 3.6 5.7 3.6 9S14.4 18.3 12 21M12 3C9.6 5.7 8.4 8.7 8.4 12S9.6 18.3 12 21"></path>
      </svg>
      <span>EN</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-muted-ash);
    background: var(--color-shell);
  }

  .header-row {
    max-width: 1480px;
    margin: 0 auto;
    padding: 32px 56px;
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr) 180px;
    align-items: center;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    border-bottom: none;
  }

  .brand:hover {
    border-bottom: none;
  }

  .brand-name {
    color: var(--color-signal-cyan);
    font-size: clamp(30px, 3.2vw, 44px);
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0;
  }

  .nav-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(18px, 3vw, 44px);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav-row::-webkit-scrollbar {
    display: none;
  }

  .nav-link {
    flex: 0 0 auto;
    padding: 8px 0;
    border: 1px solid transparent;
    color: var(--color-dim-gray);
    font-size: 17px;
    font-weight: 600;
    line-height: 1;
  }

  .nav-link:hover {
    color: var(--color-midnight-oil);
  }

  .nav-link.active {
    color: var(--color-midnight-oil);
    font-weight: 800;
  }

  .language-pill {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-width: 88px;
    min-height: 52px;
    padding: 0 18px;
    border: 1px solid var(--color-muted-ash);
    border-radius: 999px;
    color: var(--color-midnight-oil);
    background: rgba(255, 255, 255, 0.54);
    font-size: 16px;
    font-weight: 750;
    box-shadow: 0 12px 30px rgba(24, 25, 29, 0.04);
  }

  .language-pill svg {
    width: 23px;
    height: 23px;
    stroke: var(--color-midnight-oil);
    stroke-width: 1.9;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 720px) {
    .header-row {
      grid-template-columns: 1fr auto;
      gap: 16px;
      padding: 24px 20px 18px;
    }

    .nav-row {
      grid-column: 1 / -1;
      justify-content: flex-start;
      width: 100%;
      padding-bottom: 2px;
      gap: 22px;
    }

    .nav-link {
      font-size: 15px;
    }

    .language-pill {
      min-width: 74px;
      min-height: 44px;
      padding: 0 14px;
    }
  }
</style>
