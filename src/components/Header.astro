---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
];
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---
<header class="site-header">
  <div class="header-row">
    <a href="/" class="brand" aria-label="Go to home">
      <span class="brand-name">SUPA</span>
    </a>

    <nav class="nav-row" aria-label="Primary navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-muted-ash);
    background: var(--color-shell);
  }

  .header-row {
    max-width: 1480px;
    margin: 0 auto;
    padding: 32px 56px;
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    align-items: center;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    border-bottom: none;
  }

  .brand:hover {
    border-bottom: none;
  }

  .brand-name {
    color: var(--color-signal-cyan);
    font-size: clamp(30px, 3.2vw, 44px);
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0;
  }

  .nav-row {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(18px, 3vw, 44px);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav-row::-webkit-scrollbar {
    display: none;
  }

  .nav-link {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 0;
    border: 1px solid transparent;
    color: var(--color-dim-gray);
    font-size: 17px;
    font-weight: 600;
    line-height: 1;
  }

  .nav-link:hover {
    color: var(--color-midnight-oil);
  }

  .nav-link.active {
    color: var(--color-midnight-oil);
    font-weight: 800;
  }

  @media (max-width: 720px) {
    .header-row {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 24px 20px 18px;
    }

    .nav-row {
      grid-column: 1 / -1;
      justify-content: flex-start;
      width: 100%;
      padding-bottom: 2px;
      gap: 22px;
    }

    .nav-link {
      font-size: 15px;
    }
  }
</style>
