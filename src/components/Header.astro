---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---
<header class="site-header">
  <div class="header-row">
    <a href="/" class="brand" aria-label="Go to home">
      <span class="brand-mark">SK</span>
      <span class="brand-copy">
        <span class="brand-name">SupaKang</span>
        <span class="brand-subtitle">AI-native product log</span>
      </span>
    </a>

    <nav class="nav-row" aria-label="Primary navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(52, 59, 73, 0.85);
    background: rgba(8, 9, 11, 0.92);
    backdrop-filter: blur(14px);
  }

  .header-row {
    max-width: 1280px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    border-bottom: none;
  }

  .brand:hover {
    border-bottom: none;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--color-accent-orange);
    border-radius: 8px;
    color: var(--color-accent-orange);
    background: rgba(255, 122, 26, 0.08);
    font-size: 13px;
    line-height: 1;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-name {
    color: var(--color-ghost-white);
    font-size: 15px;
    line-height: 1.1;
  }

  .brand-subtitle {
    color: var(--color-dim-gray);
    font-size: 12px;
    line-height: 1.1;
  }

  .nav-row {
    display: flex;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav-row::-webkit-scrollbar {
    display: none;
  }

  .nav-link {
    flex: 0 0 auto;
    padding: 8px 10px;
    border: 1px solid transparent;
    border-radius: 8px;
    color: var(--color-dim-gray);
    font-size: 14px;
    line-height: 1;
  }

  .nav-link:hover {
    color: var(--color-ghost-white);
    border-color: var(--color-muted-ash);
    background: var(--color-panel);
  }

  .nav-link.active {
    color: var(--color-midnight-oil);
    border-color: var(--color-accent-orange);
    background: var(--color-accent-orange);
  }

  @media (max-width: 720px) {
    .header-row {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
      padding: 14px 18px;
    }

    .nav-row {
      width: 100%;
      padding-bottom: 2px;
    }
  }
</style>
