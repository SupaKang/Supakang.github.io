---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  visual: string;
  filterable?: boolean;
  searchText?: string;
  headingLevel?: 'h2' | 'h3';
}

const {
  post,
  visual,
  filterable = false,
  searchText = '',
  headingLevel = 'h2',
} = Astro.props;

const HeadingTag = headingLevel;
const filterAttributes = filterable
  ? {
      'data-post-card': '',
      'data-category': post.data.category,
      'data-search': searchText,
    }
  : {};

function formatDate(date: Date) {
  return date.toLocaleDateString('en', { month: 'short', day: '2-digit' });
}
---

<a
  href={`/blog/${post.id}/`}
  class:list={['story-card', visual]}
  {...filterAttributes}
>
  <span class="card-category">{post.data.category}</span>
  <div class="visual-layer" aria-hidden="true">
    <span class="visual-chip chip-one"></span>
    <span class="visual-chip chip-two"></span>
    <span class="visual-chip chip-three"></span>
  </div>
  <div class="card-content">
    <HeadingTag>{post.data.title}</HeadingTag>
    <div class="card-meta">
      <span>{formatDate(post.data.pubDate)}</span>
      <span class="meta-divider">|</span>
      <span>{post.data.readMin ?? '-'} Min Read</span>
      {post.data.project && (
        <>
          <span class="meta-divider">|</span>
          <span>{post.data.project}</span>
        </>
      )}
    </div>
  </div>
</a>

<style>
  .story-card {
    position: relative;
    min-height: 320px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    border: 0;
    border-radius: 24px;
    color: #ffffff;
    background:
      linear-gradient(180deg, rgba(15, 18, 26, 0.06), rgba(5, 6, 9, 0.72)),
      var(--visual-base);
    box-shadow: 0 22px 48px rgba(24, 25, 29, 0.12);
    isolation: isolate;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .story-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 68px rgba(24, 25, 29, 0.18);
  }

  .story-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(125deg, rgba(255, 255, 255, 0.16), transparent 38%),
      var(--visual-base);
    transform: scale(1.02);
  }

  .story-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, transparent 25%, rgba(0, 0, 0, 0.42) 58%, rgba(0, 0, 0, 0.74) 100%);
  }

  .visual-ai {
    --visual-base:
      linear-gradient(135deg, #3458ff 0%, #18243d 44%, #07090f 100%);
  }

  .visual-workflow {
    --visual-base:
      linear-gradient(135deg, #16a879 0%, #14373d 42%, #080c10 100%);
  }

  .visual-cad {
    --visual-base:
      linear-gradient(135deg, #13151d 0%, #365dd8 46%, #f1a33a 100%);
  }

  .visual-sun {
    --visual-base:
      linear-gradient(135deg, #ffbf48 0%, #df5c32 44%, #202126 100%);
  }

  .visual-rain {
    --visual-base:
      linear-gradient(135deg, #7cc7ff 0%, #3158f5 48%, #111827 100%);
  }

  .visual-system {
    --visual-base:
      linear-gradient(135deg, #7166ff 0%, #243048 46%, #08090f 100%);
  }

  .card-category {
    position: absolute;
    top: 22px;
    left: 22px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 13px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    color: #ffffff;
    font-size: 14px;
    font-weight: 650;
    backdrop-filter: blur(16px);
  }

  .visual-layer {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .visual-layer::before {
    content: "";
    position: absolute;
    inset: 18% -10% auto 42%;
    height: 36%;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 32px;
    transform: rotate(-12deg);
  }

  .visual-chip {
    position: absolute;
    display: block;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }

  .chip-one {
    width: 44%;
    height: 10px;
    top: 24%;
    left: 12%;
    transform: rotate(-8deg);
  }

  .chip-two {
    width: 30%;
    height: 10px;
    top: 34%;
    left: 20%;
    transform: rotate(-8deg);
  }

  .chip-three {
    width: 54%;
    height: 10px;
    top: 44%;
    left: 8%;
    transform: rotate(-8deg);
  }

  .card-content {
    width: 100%;
    display: grid;
    gap: 16px;
    padding: 30px;
  }

  .card-content :is(h2, h3) {
    max-width: 760px;
    color: #ffffff;
    font-size: clamp(22px, 1.9vw, 30px);
    line-height: 1.08;
    text-wrap: balance;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    align-items: center;
    color: rgba(255, 255, 255, 0.76);
    font-size: 15px;
    font-weight: 650;
  }

  .meta-divider {
    color: rgba(255, 255, 255, 0.42);
  }

  @media (max-width: 720px) {
    .story-card {
      min-height: 360px;
    }

    .card-content {
      padding: 24px;
    }
  }
</style>
